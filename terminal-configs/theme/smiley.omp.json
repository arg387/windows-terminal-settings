{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "var": {
    "Start": "Start 😊"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "leading_diamond": "\ue0c2\ue0c3",
          "properties": {
            "arch": "\uf303",
            "debian": "\uf306",
            "fedora": "\uf30a",
            "linux": "\uf17c",
            "macos": "\uf179",
            "manjaro": "\uf312",
            "opensuse": "\uf314",
            "ubuntu": "\uf31b",
            "windows": "\uf17a"
          },
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}} ",
          "foreground": "#3c096c",
          "background": "#caf0f8",
          "type": "os",
          "style": "diamond"

        },
        {
          "template": " <#ffffff>\uf007</> {{ .UserName }} ",
          "foreground": "#f4f4f4",
          "background": "#3905f7",
          "type": "session",
          "style": "powerline"
        },
        {
          "properties": {
            "folder_icon": "\uf114",
            "folder_separator_icon": "\\",
            "home_icon": "\ueb06",
            "style": "full"
          },
          "template": " <#000000>\uf07c \uf061</> {{ .Path }} ",
          "foreground": "#000000",
          "powerline_symbol": "\ue0c0\ue0c1",
          "background": "#6DEBA2",
          "type": "path",
          "style": "powerline"
        },
        {
          "properties": {
            "branch_icon": " <#F2CF07>\ue0a0 </#F2CF07>",
            "fetch_stash_count": true,
            "fetch_status": false,
            "fetch_upstream_icon": true
          },
          "template": " ➜ ({{ .UpstreamIcon }}{{ .HEAD }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }}) ",
          "foreground": "#F2CF07",
          "powerline_symbol": "\ue0c0\ue0c1",
          "background": "#FF2600",
          "type": "git",
          "style": "powerline"
        },
        {
          "template": " \ue718 {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }} ",
          "foreground": "#1F211F",
          "powerline_symbol": "\ue0c0\ue0c1",
          "background": "#3CFF00",
          "type": "node",
          "style": "powerline"
        },
        {
          "properties": {
            "always_enabled": true
          },
          "template": " \ueba2 {{ .FormattedMs }} ",
          "foreground": "#000000",
          "powerline_symbol": "\ue0c0\ue0c1",
          "background": "#84B8F0",
          "type": "executiontime",
          "style": "powerline"
        },
        {
          "properties": {
            "time_format": "3:04 PM"
          },
          "template": " \uf017 {{ .CurrentDate | date .Format }} ",
          "foreground": "#000000",
          "powerline_symbol": "\ue0c0\ue0c1",
          "background": "#08e4d9",
          "type": "time",
          "style": "powerline"
        },
        {
          "properties": {
            "time_format": "Jan 2 2006"
          },
          "trailing_diamond": "\ue0b1",
          "template": " \uf073 {{ .CurrentDate | date .Format }} ",
          "foreground": "#000000",
          "powerline_symbol": "\ue0c0\ue0c1",
          "background": "#FFD93D",
          "type": "time",
          "style": "powerline"
        },
        {
          "properties": {
            "always_enabled": true
          },
          "trailing_diamond": "\ue0c0\ue0c1",
          "template": " {{ if gt .Code 0 }}\uf421 {{ else }}\uf469 {{ end }}",
          "foreground": "#dd2d4a",
          "powerline_symbol": "\ue0c0\ue0c1",
          "background": "#000000",
          "type": "status",
          "style": "diamond",
          "background_templates": [
            "{{ if gt .Code 0 }}red{{ end }}"
          ]
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "leading_diamond": "\ue0c2\ue0c3",
          "properties": {
            "arch": "\uf303",
            "debian": "\uf306",
            "fedora": "\uf30a",
            "linux": "\uf17c",
            "macos": "\uf179",
            "manjaro": "\uf312",
            "opensuse": "\uf314",
            "ubuntu": "\uf31b",
            "windows": "\uf17a"
          },
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}} ",
          "foreground": "#3c096c",
          "background": "#758bfd",
          "type": "os",
          "style": "diamond"
        },
        {
          "template": " <#45F1C2><b>⚡</b></><#26C6F9><b>\uf072</b></><#26C6F9><b> {{.Var.Start}} </b></>",
          "foreground": "#CD4277",
          "background": "#000000",
          "type": "text",
          "style": "diamond",
          "trailing_diamond": "\ue0c0\ue0c1"
        }
      ],
      "newline": true
    }
  ],
  "version": 3,
  "final_space": true
}
